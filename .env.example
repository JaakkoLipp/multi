# --- LiteLLM gateway (OpenAI-compatible HTTP) ---------------------------------
# Point this at your LiteLLM gateway. Any OpenAI-compatible endpoint works.
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-...

# --- Per-stage models (configured independently) ------------------------------
ORCHESTRATOR_MODEL=gpt-4o          # a stronger model for decomposition
DESIGNER_MODEL=gpt-4o              # a stronger model for the spec
DEVELOPER_MODEL=qwen2.5-coder      # a local coder model is fine here
TESTER_MODEL=qwen2.5-coder         # a local coder model is fine here
REVIEWER_MODEL=gpt-4o              # critic for the review loop (defaults to DESIGNER_MODEL)

# --- Engine knobs -------------------------------------------------------------
MAX_WBS_ITEMS=6
MAX_REWORK_ATTEMPTS=2
TEST_TIMEOUT_MS=30000
DESIGNER_CONCURRENCY=1
DEVELOPER_CONCURRENCY=2
TESTER_CONCURRENCY=2

# --- Review loop (critic reviews code before testing; rejections rework) ------
REVIEW_ENABLED=false

# --- Integration & packaging (assemble passing modules into one library) ------
PACKAGE_ENABLED=false
PACKAGE_NAME=generated-utils

# --- Quality gates (run after unit tests pass; failures route back to dev) -----
# Off by default; enable per gate (1/true/yes/on) or via the CLI --gates flag.
GATE_TYPECHECK=false   # strict `tsc --noEmit` on the generated module
GATE_LINT=false        # ESLint flat config on the generated module
GATE_COVERAGE=false    # vitest line coverage must meet COVERAGE_MIN
COVERAGE_MIN=80

# --- Optional: Langfuse tracing (left as a clean hook; not required) ----------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

{
  "name": "agent-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Concurrent multi-agent code-generation pipeline (designer -> developer -> tester) with a headless engine and a typed event stream.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts \"Build a TypeScript module string_utils exporting: slugify(text), truncateWords(text, n), countVowels(text), isPalindrome(text), titleCase(text)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.71",
    "@mastra/core": "^1.42.0",
    "ai": "^6.0.206",
    "ink": "^7.1.0",
    "log-update": "^8.0.0",
    "octokit": "^5.0.5",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
